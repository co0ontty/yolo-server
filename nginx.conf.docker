# Nginx 配置 - Docker 部署 (HTTPS)
# 前后端分离认证 - 认证由应用层 (Go server) 负责

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # HTTP 重定向到 HTTPS
    server {
        listen 80;
        server_name _;
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl;
        server_name _;

        # SSL 证书配置
        ssl_certificate /app/certs/server.crt;
        ssl_certificate_key /app/certs/server.key;

        # SSL 优化配置
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_prefer_server_ciphers on;
        ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;

        # 前端静态文件
        root /app/dist/web;
        index index.html;

        # 静态资源缓存
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|map)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }

        # CLI 下载 (不需要认证，方便远程安装)
        location /cli/ {
            alias /app/dist/cli/;
        }

        # SPA fallback - 认证由前端负责
        location / {
            try_files $uri $uri/ /index.html;
        }

        # WebSocket 代理 - 前端 (认证由应用层负责)
        location /ws {
            proxy_pass http://127.0.0.1:3100;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # WebSocket 代理 - CLI (使用 token 认证)
        location /ws/cli {
            proxy_pass http://127.0.0.1:3100;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Health check (不需要认证)
        location /health {
            proxy_pass http://127.0.0.1:3100;
        }
    }
}
